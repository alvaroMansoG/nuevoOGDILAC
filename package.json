{
  "name": "desarrollo-digital-latam",
  "version": "1.0.0",
  "description": "Dashboard de indicadores de desarrollo digital para Latinoamérica",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "build:gov-history": "python tools/build_gov_history.py",
